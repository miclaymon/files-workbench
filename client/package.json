{
  "name": "files-workbench-client",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:web:client": "vite",
    "dev:electron:client": "node scripts/dev.js",
    "build:plugins": "node scripts/build-plugins.js",
    "build:web": "vite build",
    "build:electron": "node scripts/build-server.js && node scripts/build-plugins.js --out .fw/plugins-dist && vite build && electron-builder",
    "generate": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@workbench/framework": "file:../../workbench-framework",
    "@workbench/vue": "file:../../workbench-ui-vue",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "uuid": "^14.0.0",
    "video.js": "^8.23.7",
    "vue": "^3.5.0",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^34.5.8",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.files-workbench.app",
    "productName": "Files Workbench",
    "directories": {
      "output": "dist-electron"
    },
    "artifactName": "FilesWorkbench-${version}-${arch}.${ext}",
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/v1/dist",
        "to": "."
      },
      {
        "from": "../server/v1/blacklist.yaml",
        "to": "blacklist.yaml"
      },
      {
        "from": "../config",
        "to": "config"
      },
      {
        "from": "../.fw/plugins-dist",
        "to": "plugins"
      }
    ],
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "allowScripts": {
    "electron@34.5.8": true
  }
}
