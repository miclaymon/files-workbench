node_modules/
.nuxt/
.output/
dist/
dist-electron/
.env
.env.local

# User-specific config overrides (not committed; defaults live alongside them)
config/preferences/user-preferences.json
config/keybindings/user-keybindings.json

# Client-side build artifacts
client/.nuxt/
client/dist
client/dist/
client/dist-electron/

# Go build artifacts
server/v1/dist/
server/v1/files-workbench

# Generated icon-pack assets (run scripts/install-material-icon-theme.sh)
config/plugins/material-icon-theme/vscode-material-icon-theme/

# Generated server-plugin WASM backends + emitted manifests (run npm run build:plugins).
# Source lives in client/builtin-plugins/<id>/server/; these are build outputs.
config/plugins/*/plugin.wasm
config/plugins/source-control/

# Built plugin artifacts (dev). Source lives in /plugins/<id>/; the build emits the
# per-target artifacts (client.js, server.wasm, plugin.json) + hashes here.
.fw/

# Third-party plugin install state (dev). In dev the data dir aliases config/, so
# user-installed plugins + their enable/disable state land under config/plugins/.
config/plugins/state.json

# Search index DB (dev). The fw-indexer writes its SQLite index under the data dir,
# which aliases config/ in dev.
config/index/

# Claude Code local settings
.claude/

# Server log output
server/logs/
server/v1/logs/
server/v2/logs/
